alias g='LC_ALL=en_US git'
alias git='LC_ALL=en_US git'
alias minikube='LC_ALL=en_US minikube'
alias py='python'
alias nj="NVIM_APPNAME=nvim-james nvim"
alias l='ls -lah'
alias tf='terraform'
alias j='z'
alias ..='cd ..'
alias ...='cd ../..'

alias cn="caffeinate"
alias cl="claude"

# Source work-specific aliases if available (not tracked in public dotfiles)
[[ -f ~/.zsh_aliases_work ]] && source ~/.zsh_aliases_work

nv() {
  if [[ -f "poetry.lock" ]]; then
    poetry run nvim "$@"
  elif [[ -f "uv.lock" ]]; then
    uv run nvim "$@"
  else
    command nvim "$@"
  fi
}
