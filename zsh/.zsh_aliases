alias g='LC_ALL=en_US git'
alias git='LC_ALL=en_US git'
alias minikube='LC_ALL=en_US minikube'
alias py='python'
alias nj="NVIM_APPNAME=nvim-james nvim"
alias l='ls -lah'
alias tf='terraform'
alias j='z'
alias ..='cd ..'
alias ...='cd ../..'

# RentSpree
# alias prefix-dev="gcloud container clusters get-credentials REDACTED-CLUSTER --zone us-west1-a --project REDACTED-PROJECT && HTTPS_PROXY=\"http://localhost:8888\""
alias prefix-dev="HTTPS_PROXY=\"http://localhost:8888\""
alias ssh-dev="gcloud compute ssh REDACTED-BASTION --tunnel-through-iap --project REDACTED-PROJECT --zone us-west1-a -- -L8888:127.0.0.1:8888"
alias pf-dev="prefix-dev kubectl port-forward svc/REDACTED-SERVICE -n dagster 8080:80"
alias k9s-dev="prefix-dev k9s"

# alias prefix-prod="gcloud container clusters get-credentials REDACTED-CLUSTER --zone us-west1-a --project REDACTED-PROJECT && HTTPS_PROXY=\"http://localhost:8888\""
alias prefix-prod="HTTPS_PROXY=\"http://localhost:8888\""
alias ssh-prod="gcloud compute ssh REDACTED-BASTION --tunnel-through-iap --project REDACTED-PROJECT --zone us-west1-a -- -L8888:127.0.0.1:8888"
alias pf-prod="prefix-prod kubectl port-forward svc/REDACTED-SERVICE -n dagster 8081:80"
alias k9s-prod="prefix-prod k9s"
alias pf-dh="prefix-prod kubectl port-forward svc/REDACTED-SERVICE -n datahub 8080:8080"

alias gsutil='gsutil -o "GSUtil:parallel_process_count=1"'

alias cn="caffeinate"
alias cl="claude"

nv() {
  if [[ -f "poetry.lock" ]]; then
    poetry run nvim "$@"
  elif [[ -f "uv.lock" ]]; then
    uv run nvim "$@"
  else
    command nvim "$@"
  fi
}
